{
  "name": "@seamdoc/exporter-pdf",
  "version": "0.1.0",
  "description": "PDF exporter: serializes the Seamdoc render tree to PDF",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --config vitest.config.ts",
    "lint": "eslint src"
  },
  "dependencies": {
    "@pdfsmaller/pdf-encrypt-lite": "^1.0.2",
    "@seamdoc/renderer": "workspace:*",
    "@seamdoc/shared": "workspace:*",
    "@seamdoc/types": "workspace:*",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@seamdoc/core": "workspace:*",
    "@seamdoc/highlighter": "workspace:*"
  }
}
